# Server Configuration
PORT=3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/predictio?schema=public"

# Authentication
# Ensure this is a strong, random string in production
JWT_SECRET="your-super-secret-jwt-key"

# Stellar Network
# Testnet: https://horizon-testnet.stellar.org
# Public: https://horizon.stellar.org
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"

# Testnet: "Test SDF Network ; September 2015"
# Public: "Public Global Stellar Network ; September 2015"
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_SOROBAN_RPC_URL="https://soroban-testnet.stellar.org"

# Global Prediction Market contract and operator (single-contract architecture)
# Preferred backend var:
MARKET_CONTRACT_ADDRESS=CD54GT5YEREWRZVF5TZE3Q66DABHQESCBKXNWKGO2TW7CBLOCM3BLCQ5
# Alternative backend alias:
# MARKET_CONTRACT_ID=CBJ2443XDOPG2LGODC6YTNEGZZCQEJ6WNW47XG3CTYVNGNDWDYGEA4CK
# Dev fallback (if you already only have this in frontend env):
# NEXT_PUBLIC_MARKET_CONTRACT_ID=""
USDC_CONTRACT_ADDRESS=""
OPERATOR_PUBLIC_KEY=""
OPERATOR_SECRET_KEY=""

# DIDIT Verification Integration
# Optional API Key if we need to call DIDIT API instead of just receiving webhooks
# DIDIT_API_KEY="your-didit-api-key"

# Development shortcut: trades only require authenticated wallet (no KYC)
# ENABLE_KYC=false
